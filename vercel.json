{
  "rewrites": [
    {
      "source": "/discuss/:path*",
      "destination": "https://discuss.filmglance.com/discuss/:path*"
    },
    {
      "source": "/discuss",
      "destination": "https://discuss.filmglance.com/discuss/"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=600, stale-while-revalidate=3600"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/seed/refresh",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/box-office/refresh",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/discover/refresh-release-window",
      "schedule": "15 4 * * *"
    }
  ]
}
