{
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "permissions": {
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard origin/*)",
      "Bash(git reset --hard *)",
      "Bash(git config --global *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(* > /dev/*)",
      "Bash(* >> /dev/*)"
    ]
  }
}
